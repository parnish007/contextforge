# ============================================================
# ContextForge v3.0 — Production .gitignore
# ============================================================

# ── Secrets & Environment ────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.flaskenv
*.secret
secrets.json
*.pem
*.key
*.cert
*.p12
*.pfx
service_account.json
credentials.json
google_credentials.json

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.Python
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
*.log

# ── Virtual Environments ─────────────────────────────────────
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
dist/
.next/
out/
.nuxt/
.cache/

# ── Database & Persistent State ──────────────────────────────
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-journal
data/*.db-wal
data/*.db-shm
# Keep directory structure and tracked data files
!data/.gitkeep
!data/academic_metrics.md
!data/academic_metrics.json
!data/metrics_report.json

# ── Benchmark Outputs ────────────────────────────────────────
# Legacy raw output files are gitignored; only scripts are tracked
benchmark/tmp/
benchmark/OMEGA_*.json
benchmark/omega_iter*.json
benchmark/*.tex
benchmark/*.pdf
benchmark/live_vs_mocked.txt
# Suite logs ignored (regenerated by running the suites)
benchmark/test_v5/logs/
# Track the new scientific benchmark engine and viz generator
!benchmark/engine.py
!benchmark/generate_viz.py
benchmark/abstract.txt
# Keep directory structure & committed scripts
!benchmark/*.py
!benchmark/*.md
!benchmark/EVOLUTION_LOG.md
!benchmark/final_omega_results.tex
!benchmark/ablation_report.md
!benchmark/resiliency_matrix.md

# ── Publication Assets (tracked) ─────────────────────────────
# PNGs in docs/assets/ are tracked for reproducibility
!docs/assets/*.png
!docs/assets/*.svg

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
agentscope.log
run.log
agentscope_runs/

# ── AI / IDE Tool Artifacts ──────────────────────────────────
.agents/
.claude/
.cursor/
.continue/
.copilot/
.aider*

# ── OS Artifacts ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.bak
*~
.project
.classpath
.settings/

# ── TypeScript / MCP Server ──────────────────────────────────
src/server/dist/
src/server/node_modules/
src/server/*.js.map

# ── Local Docs (kept local, not for OSS repo) ────────────────
CLAUDE.md
OMEGA_SPEC.md
OMEGA_SPEC.docx
*.local.md

# ── Forge Snapshots (runtime state) ──────────────────────────
.forge/
*.forge

# ── Runtime Outputs (root level) ─────────────────────────────
stress_report.json
stress_report.tex

# ── Data — additional runtime directories ─────────────────────
data/l1_cache/
data/*.tex

# ── Benchmark — extended suite logs and generated outputs ─────
benchmark/logs/
!benchmark/logs/.gitkeep
benchmark/metrics_report.json

# ── Papers subfolders (generated images) ─────────────────────
papers/images/
