# ============================================================
# ContextForge v5.0 — .gitignore
# ============================================================
#
# Philosophy:
#   Track: source code, docs, benchmark scripts, JSON result archives,
#          PNG figures (300 DPI), LaTeX sources, .env.example
#   Ignore: secrets, runtime state, compiled binaries, root-level PDFs,
#           duplicate benchmark figure copies, OS/IDE cruft

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.flaskenv
*.secret
secrets.json
*.pem
*.key
*.cert
*.p12
*.pfx
service_account.json
credentials.json
google_credentials.json

# Keep the safe template
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.Python
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
*.log
*.pyc

# ── Virtual Environments ──────────────────────────────────────────────────────
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ── Node / TypeScript ─────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.next/
out/
.nuxt/
.cache/

# Compiled MCP server output — regenerated with `npm run build`
src/server/dist/
src/server/node_modules/
src/server/*.js.map
mcp/node_modules/
mcp/__pycache__/
# Keep compiled dist so users can run without a build step
!mcp/dist/
!mcp/dist/index.js
!mcp/dist/index.d.ts

# ── Database & Persistent State ───────────────────────────────────────────────
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/l1_cache/
data/*.tex

# Keep tracked data files (mathematical derivations + metrics)
!data/.gitkeep
!data/academic_metrics.md
!data/academic_metrics.json
!data/metrics_report.json

# ── Compiled Papers (root-level) ──────────────────────────────────────────────
# PDFs at the repo root are LaTeX compilation artifacts, not source files.
# .tex sources are tracked; regenerate PDFs locally with pdflatex.
contextforge*.pdf
*.docx

# ── Forge Snapshots (runtime encrypted state) ─────────────────────────────────
.forge/
*.forge

# ── Runtime Output (root level) ───────────────────────────────────────────────
stress_report.json
stress_report.tex
abstract.txt
benchmark/abstract.txt

# ── Log Files ─────────────────────────────────────────────────────────────────
logs/
agentscope.log
run.log
agentscope_runs/
benchmark/logs/
!benchmark/logs/.gitkeep

# ── Benchmark — Raw Iteration Outputs ─────────────────────────────────────────
# These JSON dumps are regenerated by running the benchmark scripts.
benchmark/OMEGA_*.json
benchmark/omega_iter*.json
benchmark/tmp/
benchmark/metrics_report.json

# Benchmark figure PDFs — PNGs are tracked; PDFs are large duplicates.
# The .tex files only reference research/figures/output/ via \graphicspath,
# so these benchmark copies are never used by pdflatex.
benchmark/benchmark_memory/figures/output/*.pdf

# Keep everything else in benchmark/ (scripts, datasets, JSON results)
!benchmark/*.py
!benchmark/*.md

# ── Local Docs (internal — not for public OSS repo) ──────────────────────────
CLAUDE.md
OMEGA_SPEC.md
OMEGA_SPEC.docx
*.local.md
docs/superpowers/

# ── AI / IDE Tool Artifacts ───────────────────────────────────────────────────
.agents/
.claude/
.cursor/
.continue/
.copilot/
.aider*

# ── OS Artifacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.bak
*~
.project
.classpath
.settings/

# ── Research Figures (policy note) ───────────────────────────────────────────
# PNG figures in research/figures/ and research/figures/output/ are TRACKED.
# They are the authoritative 300 DPI publication figures and are small
# enough (< 500 KB each) to keep in git.
#
# PDF versions of research figures ARE tracked — they are needed for
# pdflatex compilation and arXiv/conference submission.
# Do NOT add *.pdf or research/figures/**/*.pdf to this file.

# Papers directory — generated images only (sources tracked)
papers/images/
