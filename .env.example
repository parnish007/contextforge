# ContextForge Nexus v5.0 — Environment Configuration
# Copy to .env and fill in your values.
# Keys marked [OPTIONAL] have a free local fallback — the system runs without them.

# ─── Project ────────────────────────────────────────────────
PROJECT_ID=contextforge-default

# ─── Sentry Agent (file watcher) ────────────────────────────
SENTRY_WATCH_PATH=.
SENTRY_BATCH_THRESHOLD=3
SENTRY_PAUSE_TIMEOUT=30

# ─── Database Backend ────────────────────────────────────────
# Options: sqlite | supabase | postgres
DB_BACKEND=sqlite
DB_PATH=./data/contextforge.db

# ─── LLM Providers ───────────────────────────────────────────
# Priority order: FALLBACK_CHAIN. Leave a key blank to skip that provider.
# The system runs fully without any API key using Ollama or rule-based fallback.
AGENT_LLM_DEFAULT=groq
FALLBACK_CHAIN=groq,gemini,openrouter,ollama

# Groq — fast, generous free tier (recommended)
# Get key: https://console.groq.com/
GROQ_API_KEY=

# Google Gemini
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — aggregated access to 100+ models
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama — fully local, no key needed
# Install: https://ollama.com/download  →  then: ollama pull llama3.3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3

# ─── Web Search (for Researcher agent) ───────────────────────
# Tavily — best quality, free tier available
# Get key: https://app.tavily.com/
TAVILY_API_KEY=

# Serper — Google search API, fallback
# Get key: https://serper.dev/
SERPER_API_KEY=

# DuckDuckGo is used automatically when both above are missing (no key required, rate-limited)

# ─── Nexus v5.0 ──────────────────────────────────────────────
# Path to PROJECT_CHARTER.md (ReviewerGuard ground truth for adversarial defense)
CHARTER_PATH=PROJECT_CHARTER.md

# AES-256-GCM encryption key for .forge snapshots
# Change this to a strong random string before using snapshot in production
FORGE_SNAPSHOT_KEY=contextforge-default-key

# Auto-checkpoint interval in minutes (0 = disable idle checkpoint)
IDLE_MINUTES=15

# ─── Features ────────────────────────────────────────────────
CONTEXT_SAVE_MODE=batched
PREFERENCE_LEARNING=false

# ─── Server ──────────────────────────────────────────────────
SERVER_MODE=local
DASHBOARD_PORT=3777
