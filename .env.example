# ContextForge v3.0 — Environment Configuration
# Copy to .env and fill in your values

# ─── Project ────────────────────────────────────────
PROJECT_ID=contextforge-default

# ─── Sentry Agent ───────────────────────────────────
SENTRY_WATCH_PATH=.
SENTRY_BATCH_THRESHOLD=3
SENTRY_PAUSE_TIMEOUT=30

# ─── Database Backend ───────────────────────────────
# Options: sqlite | supabase | postgres
DB_BACKEND=sqlite
DB_PATH=./data/contextforge.db

# ─── LLM Providers ─────────────────────────────────
AGENT_LLM_DEFAULT=groq
FALLBACK_CHAIN=groq,cerebras,gemini,openrouter,ollama
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3

# ─── Features ───────────────────────────────────────
CONTEXT_SAVE_MODE=batched
PREFERENCE_LEARNING=false

# ─── Server ─────────────────────────────────────────
SERVER_MODE=local
DASHBOARD_PORT=3777
